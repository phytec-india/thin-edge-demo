diff --git a/Te-PD-25.1.0/Te-applications/recipes-phytedge/phytedge-modbus/files/PHYTedge-Modbus-Plugin/docker_install.sh b/Te-PD-25.1.0/Te-applications/recipes-phytedge/phytedge-modbus/files/PHYTedge-Modbus-Plugin/docker_install.sh
